<!-- livestream evergreen -->
<div class="embed">
  <div class="video">
    <iframe src="https://www.youtube.com/embed/{{ hero.video_id }}"
      width="854"
      height="400"
      frameborder="0"
      scrolling="no"
      allowfullscreen="true"
fetchpriority="high">
    </iframe>
  </div>
  <div class="chat">
    <iframe src="https://www.youtube.com/live_chat?v={{ hero.video_id  }}&embed_domain={{ domain_parent }}"
      fetchpriority="high">
    </iframe>
  </div>
</div>
<!-- / livestream evergreen -->
