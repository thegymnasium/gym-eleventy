{%- if hero -%}
  {%- if not hero_cat -%}
    <em>{ Hero Module }</em>
    <p>Your images won't work unless you provide a hero_cat variable</p>
  {%- endif  -%}
  {%- if hero.img.url -%}
    {# TODO: do something if we have an anomalous URL that doesn't fit the pattern below #}
  {%- endif -%}
  {%- if not heroClass -%}
    {%- set heroClass = "hero" -%}
  {%- endif -%}

  <article class="{{ heroClass }} {{ hero.type }} {{ hero.layout }}" id="{{ hero.slug }}">
    <div class="container">
      {%- if hero.img -%}
        <div class="image">
          {%- macro picture() -%}
            <picture decoding="async" fetchpriority="high">
              <source srcset="/img/hero/{{ hero_cat }}/{{ hero.slug }}/{{ hero.slug }}-768w.{{ hero.img.format or 'jpg' }}" width="768" height="714" media="(min-width: 1200px)">
              <img alt="{{ hero.img.description }}" src="/img/hero/{{ hero_cat }}/{{ hero.slug }}/{{ hero.slug }}-1280w.{{ hero.img.format or 'jpg' }}" width="1280" height="720">
            </picture>
          {%- endmacro -%}
          {%- if hero.cta.url | is_external_link -%}
            {%- external_link hero.cta.url, picture() -%}
          {%- else -%}
            <a href="{{ hero.cta.url }}">{{ picture() }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if hero.slug == 'take5-tutorials' -%}
        {% include "modules/hero/evergreens/partial-take5-tutorials.njk" %}
      {%- endif -%}

      {%- set tutorial = tutorials[hero.id] -%}
      {%- if tutorial -%}
        <div class="image">
          {%- macro img() -%}
            <img alt="{{ tutorial.title }} video poster."
            srcset="/img/tutorials/poster/{{ hero.id | lower }}.jpg 1280w,
                    /img/tutorials/hero/{{ hero.id | lower }}.jpg 1920w"
            sizes="(max-width: 75em) 100vw, 50vw"
            src="/img/tutorials/poster/{{ hero.id | lower }}.jpg"
            decoding="async"
            fetchpriority="high"
            width="1280"
            height="720">
          {%- endmacro -%}
          <a href="/courses/take5/{{ tutorial.title | slugify }}">{{ img() }}</a>
        </div>

        <header>
          <hgroup>
            {%- if hero.subtitle -%}
              <p class="subhead caps"><strong>{{ hero.subtitle }}</strong></p>
            {%- endif -%}
            <h1>{{ tutorial.title }}</h1>
            {%- if tutorial.topic -%}
              <p class="subhead caps topic"><span>Take 5</span> {{ tutorial.topic }}</p>
            {%- endif -%}
          </hgroup>
          <p>{{ tutorial.description }}</p>
          <div class="cta">
            <a href="/courses/take5/{{ tutorial.title | slugify }}" class="btn">{{ hero.cta.label }}</a>
          </div>
        </header>

      {%- else -%}
        <header>
          <hgroup>
            {%- if hero.subtitle -%}
              <p class="subhead caps"><strong>{{ hero.subtitle }}</strong></p>
            {%- endif -%}
            <h1>{{ hero.title }}</h1>
          </hgroup>

          {%- if hero.guest -%}
            <p class="guest">{{ hero.guest }}</p>
          {%- else -%}
            <p>{{ hero.description }}</p>
          {%- endif -%}

          <div class="cta">
            {%- if hero.cta.url | is_external_link -%}
              {%- external_link hero.cta.url, hero.cta.label, 'btn' -%}
            {%- else -%}
              <a href="{{ hero.cta.url }}" class="btn">{{ hero.cta.label }}</a>
            {%- endif -%}
          </div>
        </header>
      {%- endif -%}
    </div>
  </article>

{%- else -%}
  <em>{ Hero Module Placeholder }</em>
  <p>Pass in the hero variable to make this work</p>
{%- endif -%}
