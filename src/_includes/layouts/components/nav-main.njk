<nav class="main" aria-label="Main">
  <a href="/">
    <img alt="{{config.main.meta.author}} logo, to the homepage." srcset="{{config.main.logos.main.white.srcset}}" src="{{config.main.logos.main.white.src}}" width="208" height="24" decoding="async" fetchpriority="high">
  </a>
  <div class="wrapper">
    <ul role="list">
      {%- for link in config.main.header.nav.main | replace("GYM_ROOT_URL", "") | replace("GYM_LMS_URL", config.main.urls.lms) | replace("GYM_MFE_URL", config.main.urls.mfe) -%}
      <li>
        <a href="{{link.href}}"{%- if (link.href in permalink) or (nav.parent in link.href) -%} class="active" aria-current="page" {%- endif -%}>{{link.label}}</a>
      </li>
      {%- endfor -%}
    </ul>


{%- set auth %}
<ul class="auth logged-in" role="list">
  {%- for link in config.main.header.nav.auth.private | replace("GYM_ROOT_URL", "") | replace("GYM_LMS_URL", config.main.urls.lms) -%}
    <li>
      <a href="{{link.href}}"{%- if link.class %} class="{{link.class}}"{%- endif -%}{%- if link.attr %} {{link.attr}}{%- endif -%}>{{link.label}}</a>
    </li>
  {%- endfor -%}
</ul>
{% endset %}

<is-land on:ready>
  <ul class="auth" role="list">
  {%- for link in config.main.header.nav.auth.public | replace("GYM_ROOT_URL", "") | replace("GYM_LMS_URL", config.main.urls.lms) -%}
    {%- if not link.disabled -%}<li{%- if link.parent_attr %} {{link.parent_attr}}{%- endif -%}>
      <a{%- if link.href %} href="{{link.href}}"{%- endif -%}{%- if link.class %} class="{{link.class}}"{%- endif -%}{%- if link.attr %} {{link.attr}}{%- endif -%}>{{link.label}}</a>
    </li>{%- endif -%}
  {%- endfor -%}
  </ul>

{% edge "njk", auth %}
  {% if eleventy.edge.cookies.edxloggedin %}
    <template data-island="replace">
    <!-- edxloggedin:{{ eleventy.edge.cookies.edxloggedin }} -->
    {{ _ | safe }}
    </template>
  {% endif %}
{% endedge %}

</is-land>

  </div>
</nav>
