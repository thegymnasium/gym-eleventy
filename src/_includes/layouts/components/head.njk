{%- set metaTitle = config.meta.title -%}
{%- if meta.title -%}
  {%- set metaTitle = meta.title -%}
{%- endif -%}
{%- set metaDescription = config.meta.description -%}
{%- if meta.description -%}
  {%- set metaDescription = meta.description -%}
{%- endif -%}
{%- set metaAuthor = config.meta.author -%}
{%- set metaUrl -%}{{ config.urls.production }}{{ page.url }}{%- endset -%}
{# Allow overriding metaUrl via the page meta #}
{%- if meta.canonicalUrl -%}
  {%- set metaUrl = meta.canonicalUrl -%}
{%- endif -%}
{%- set metaImg -%}{{ config.urls.production }}{{ config.meta.og_img }}{%- endset -%}
{%- if meta.img -%}
  {%- set metaImg -%}{{ config.urls.production }}{{ meta.img }}{%- endset -%}
{%- endif -%}
{# meta robots defaults #}
{%- set robotsDisallow = "noindex, nofollow, noimageindex, noarchive, nosnippet, nocache" -%}
{%- if config.urls.root == config.urls.production -%}
  {%- set metaRobots = "index, follow" -%}
  {%- if meta.robots -%}
    {%- set metaRobots = meta.robots -%}
  {%- endif -%}
{%- else -%}
  {%- set metaRobots = robotsDisallow -%}
{%- endif -%}
{# automatically exlude unindexed pages #}
{%- if (eleventyExcludeFromCollections or meta.sitemapExclude) -%}
  {%- set metaRobots = robotsDisallow -%}
{%- endif -%}

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if meta.title %}{{ meta.title }} | {% endif %}{{ config.meta.title }}</title>

<link rel="preload" fetchpriority="high" as="style" href="{{ '/css/global.css' | cachebust }}">

{%- set preload_images = meta.preload_image %}
{%- if preload_images %}
  {%- if preload_images.poster %}
    <link rel="preload" fetchpriority="high" as="image" href="{{ preload_images.poster }}">
  {%- elif preload_images.hero %}
    <link rel="preload" fetchpriority="high" as="image" href="{{ preload_images.hero }}">
  {%- endif %}
  {%- if preload_images.poster_breakpoint %}
    <link rel="preload" fetchpriority="high" as="image" media="max-width: 74.99em" href="{{ preload_images.poster_breakpoint }}">
    <link rel="preload" fetchpriority="high" as="image" media="min-width: 75em" href="{{ preload_images.hero_breakpoint }}">
  {%- endif %}
{%- endif %}

<meta name="robots" content="noai, noimageai, {{ metaRobots }}">
<meta name="author" content="{{ metaAuthor }}">
<meta name="generator" content="{{ eleventy.generator }}">
<meta http-equiv="x-ua-compatible" content="ie=edge">

<link rel="canonical" href="{{ metaUrl }}">
<meta property="og:url" content="{{ metaUrl }}">

<meta property="og:site_name" content="{{ metaAuthor }}">
<meta property="og:title" content="{{ metaTitle }}">

<meta name="description" content="{{ metaDescription }}">
<meta property="og:description" content="{{ metaDescription }}">

<meta property="og:image:alt" content="{{ metaTitle.split(' |')[0] | trim }}.">
<meta property="og:image" content="{{ metaImg }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="628">

<meta property="og:type" content="website">
<meta property="og:locale" content="en_US">

<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/favicon-180.png">
<link rel="manifest" href="/manifest.json">

<link rel="stylesheet" fetchpriority="high" href="{{ '/css/global.css' | cachebust }}">
{# Allows piping in page-specific CSS files - probably not a "recommended" practice. However, we have implemented this to support the collections index page and prism js highlighting on tutorial transcripts #}
{%- if meta.css -%}
  {%- if meta.css | is_object -%}
    {%- for item in meta.css -%}
      {%- set link = item.link -%}
      {%- if item.cachebust -%}
        {%- set link = item.link | cachebust -%}
      {%- endif -%}
      <link rel="stylesheet" fetchpriority="high" href="{{ link }}">
    {%- endfor -%}
  {%- else -%}
    <link rel="stylesheet" fetchpriority="high" href="{{ meta.css | cachebust }}">
  {%- endif -%}
{%- endif -%}

{% block head %}{% endblock %}

{# TODO: figure out how to include schema in the head automatically #}

{%- if meta.schema -%}
<!-- start schema -->
{%- include 'modules/schema/' + meta.schema.type + '.njk' ignore missing -%}
<!-- end schema -->
{%- endif -%}
