{
  "name": "gym-eleventy",
  "version": "1.0.0",
  "description": "Gymnasium v3 frontend static site",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "clean": "rimraf dist/* --glob",
    "dotenvx": "dotenvx",
    "dev": "dotenvx run -f .env.development -- npm run start",
    "parallel:dev": "dotenvx run -f .env.tutor-dev -- npx netlify dev",
    "parallel:local": "dotenvx run -f .env.tutor-local -- npx netlify dev",
    "start": "dotenvx run -- npm-run-all clean watch:11ty",
    "build:11ty": "eleventy",
    "watch:11ty": "eleventy --serve --watch",
    "build:dev": "export NODE_ENV=development; export ELEVENTY_ENV=development; dotenvx run -f .env.development -- npm-run-all build:11ty",
    "build": "export NODE_ENV=production; export ELEVENTY_ENV=production; dotenvx run -- npm-run-all build:11ty"
  },
  "keywords": [
    "Eleventy"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-fetch": "^4.0.1",
    "@11ty/eleventy-img": "^4.0.2",
    "@11ty/is-land": "^4.0.0",
    "@dotenvx/dotenvx": "^1.11.3",
    "@types/markdown-it": "^14.1.2",
    "11ty-edge": "git+https://git@github.com/gymnasium/11ty-edge.git#main",
    "html-minifier-terser": "^7.2.0",
    "isomorphic-dompurify": "^2.24.0",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-eleventy-img": "^0.10.2",
    "netlify-cli": "^20.0.3",
    "netlify-plugin-cache": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "rss-parser": "^3.13.0",
    "sass": "^1.87.0",
    "sass-embedded": "^1.87.0",
    "sharp": "^0.34.1"
  },
  "overrides": {
    "esbuild": "0.25.3"
  }
}
